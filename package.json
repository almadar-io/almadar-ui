{
  "name": "@almadar/ui",
  "version": "1.0.31",
  "description": "React UI components, hooks, and providers for Almadar",
  "type": "module",
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./context": {
      "import": "./dist/context/index.js",
      "types": "./dist/context/index.d.ts"
    },
    "./renderer": {
      "import": "./dist/renderer/index.js",
      "types": "./dist/renderer/index.d.ts"
    },
    "./stores": {
      "import": "./dist/stores/index.js",
      "types": "./dist/stores/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./components/organisms/game/three": {
      "import": "./dist/components/organisms/game/three/index.js",
      "types": "./dist/components/organisms/game/three/index.d.ts"
    },
    "./components/organisms/game/TraitStateViewer": {
      "import": "./components/organisms/game/TraitStateViewer.tsx",
      "types": "./components/organisms/game/TraitStateViewer.tsx"
    },
    "./components/organisms/game/TraitSlot": {
      "import": "./components/organisms/game/TraitSlot.tsx",
      "types": "./components/organisms/game/TraitSlot.tsx"
    },
    "./templates": {
      "import": "./templates/index.ts",
      "types": "./templates/index.ts"
    },
    "./themes/*.css": "./themes/*.css",
    "./index.css": "./index.css"
  },
  "files": [
    "dist",
    "themes"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@almadar/core": "workspace:*",
    "@almadar/evaluator": "workspace:*",
    "@almadar/patterns": "workspace:*",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "lucide-react": "^0.344.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "three": "^0.160.0",
    "@react-three/fiber": "^8.15.0",
    "@react-three/drei": "^9.92.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@storybook/addon-links": "^10.2.6",
    "@storybook/addon-themes": "^10.2.6",
    "@storybook/react": "^10.2.6",
    "@storybook/react-vite": "^10.2.6",
    "storybook": "^10.2.6",
    "@vitejs/plugin-react": "^4.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@vitest/ui": "^1.4.0",
    "jsdom": "^24.0.0",
    "@storybook/addon-docs": "^10.2.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar.git",
    "directory": "packages/almadar-ui"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "ui",
    "react",
    "components",
    "hooks"
  ]
}
