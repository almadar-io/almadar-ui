{
  "name": "@almadar/ui",
  "version": "2.15.12",
  "description": "React UI components, hooks, and providers for Almadar",
  "type": "module",
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "require": "./dist/context/index.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js",
      "require": "./dist/renderer/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./components/organisms/game/three": {
      "types": "./dist/components/organisms/game/three/index.d.ts",
      "import": "./dist/components/organisms/game/three/index.js",
      "require": "./dist/components/organisms/game/three/index.cjs"
    },
    "./components/organisms/game/TraitStateViewer": {
      "import": "./components/organisms/game/TraitStateViewer.tsx",
      "types": "./components/organisms/game/TraitStateViewer.tsx"
    },
    "./components/organisms/game/TraitSlot": {
      "import": "./components/organisms/game/TraitSlot.tsx",
      "types": "./components/organisms/game/TraitSlot.tsx"
    },
    "./templates": {
      "import": "./templates/index.ts",
      "types": "./templates/index.ts"
    },
    "./marketing": {
      "types": "./dist/marketing/index.d.ts",
      "import": "./dist/marketing/index.js",
      "require": "./dist/marketing/index.cjs"
    },
    "./docs": {
      "types": "./dist/docs/index.d.ts",
      "import": "./dist/docs/index.js",
      "require": "./dist/docs/index.cjs"
    },
    "./illustrations": {
      "types": "./dist/illustrations/index.d.ts",
      "import": "./dist/illustrations/index.js",
      "require": "./dist/illustrations/index.cjs"
    },
    "./themes/*.css": "./themes/*.css",
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js",
      "require": "./dist/locales/index.cjs"
    },
    "./locales/en.json": "./locales/en.json",
    "./locales/ar.json": "./locales/ar.json",
    "./locales/sl.json": "./locales/sl.json",
    "./index.css": "./index.css",
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "files": [
    "dist",
    "themes",
    "locales",
    "tailwind-preset.cjs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@almadar/core": ">=2.1.0",
    "@almadar/evaluator": ">=2.0.0",
    "@almadar/patterns": ">=2.0.0",
    "@almadar/runtime": ">=2.0.0",
    "clsx": "^2.1.0",
    "leaflet": "1.9.4",
    "lucide-react": "^0.344.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.2.0"
  },
  "peerDependencies": {
    "@react-three/drei": "^9.92.0 || ^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": "^7.0.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.3.0",
    "@storybook/addon-docs": "^10.2.6",
    "@storybook/addon-links": "^10.2.6",
    "@storybook/addon-themes": "^10.2.6",
    "@storybook/react": "^10.2.6",
    "@storybook/react-vite": "^10.2.6",
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/leaflet": "1.9.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@types/three": "^0.160.0",
    "@typescript-eslint/parser": "8.56.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.4.0",
    "autoprefixer": "^10.4.0",
    "babel-plugin-react-compiler": "19.0.0-beta-af1b7da-20250417",
    "eslint": "10.0.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "jsdom": "^24.0.0",
    "katex": "^0.16.0",
    "postcss": "^8.4.35",
    "react": "^19.0.0",
    "react-compiler-runtime": "19.0.0-beta-af1b7da-20250417",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "storybook": "^10.2.6",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-ui.git",
    "directory": "docs/packages/ui"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "ui",
    "react",
    "components",
    "hooks"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
