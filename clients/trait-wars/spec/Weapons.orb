      "name": "Erasure Beam",
      "entity": {
        "name": "VEV Collapser",
        "description": "Projects a 'Beam of Silence' (Local VEV Collapse). Targets do not explode; they dissolve into light (Mass Negation) as their local VEV drops to zero.",
        "fields": [
