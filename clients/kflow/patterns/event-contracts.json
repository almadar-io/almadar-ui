{
  "version": "1.0.0",
  "client": "kflow",
  "description": "KFlow client-specific event contracts",
  "contracts": {
    "concept-card": {
      "emits": [
        { "event": "UI:SELECT_CONCEPT", "trigger": "click", "payload": { "conceptId": "string", "entity": "object" } },
        { "event": "UI:EXPAND_CONCEPT", "trigger": "click", "payload": { "conceptId": "string", "expanded": "boolean" } },
        { "event": "UI:CONCEPT_ACTION", "trigger": "click", "payload": { "conceptId": "string", "action": "string" } }
      ]
    },
    "flashcard": {
      "emits": [
        { "event": "UI:FLIP_CARD", "trigger": "click", "payload": { "cardId": "string", "flipped": "boolean" } },
        { "event": "UI:MARK_STUDIED", "trigger": "click", "payload": { "cardId": "string" } },
        { "event": "UI:RESET_CARD", "trigger": "click", "payload": { "cardId": "string" } },
        { "event": "UI:NEXT_CARD", "trigger": "click", "payload": { "currentCardId": "string" } },
        { "event": "UI:PREV_CARD", "trigger": "click", "payload": { "currentCardId": "string" } }
      ]
    },
    "flashcard-stack": {
      "emits": [
        { "event": "UI:CARD_CHANGED", "trigger": "navigation", "payload": { "cardIndex": "number", "cardId": "string" } },
        { "event": "UI:STACK_COMPLETED", "trigger": "complete", "payload": { "cardIds": "array" } },
        { "event": "UI:SHUFFLE_CARDS", "trigger": "click", "payload": { "cardIds": "array" } },
        { "event": "UI:RESET_STACK", "trigger": "click", "payload": { "cardIds": "array" } }
      ]
    },
    "force-graph": {
      "emits": [
        { "event": "UI:SELECT_NODE", "trigger": "click", "payload": { "nodeId": "string", "node": "object" } },
        { "event": "UI:HOVER_NODE", "trigger": "hover", "payload": { "nodeId": "string", "node": "object" } }
      ]
    },
    "graph-legend": {
      "emits": [
        { "event": "UI:TOGGLE_LEGEND_ITEM", "trigger": "click", "payload": { "itemId": "string", "visible": "boolean" } }
      ]
    },
    "mindmap-canvas": {
      "emits": [
        { "event": "UI:MINDMAP_PAN", "trigger": "drag", "payload": { "offset": "object" } },
        { "event": "UI:MINDMAP_ZOOM", "trigger": "wheel", "payload": { "scale": "number" } },
        { "event": "UI:MINDMAP_FOCUS", "trigger": "focus", "payload": {} },
        { "event": "UI:MINDMAP_BLUR", "trigger": "blur", "payload": {} }
      ]
    },
    "mindmap-node": {
      "emits": [
        { "event": "UI:SELECT_NODE", "trigger": "click", "payload": { "nodeId": "string" } },
        { "event": "UI:EDIT_NODE", "trigger": "dblclick", "payload": { "nodeId": "string" } },
        { "event": "UI:EXPAND_NODE", "trigger": "click", "payload": { "nodeId": "string", "expanded": "boolean" } },
        { "event": "UI:AI_GENERATE", "trigger": "click", "payload": { "nodeId": "string" } }
      ]
    },
    "activation-block": {
      "emits": [
        { "event": "UI:SAVE_ACTIVATION", "trigger": "click", "payload": { "response": "string", "conceptId": "string" } },
        { "event": "UI:SKIP_ACTIVATION", "trigger": "click", "payload": { "conceptId": "string" } }
      ]
    },
    "reflection-block": {
      "emits": [
        { "event": "UI:SAVE_REFLECTION", "trigger": "click", "payload": { "reflection": "string", "sectionId": "string" } }
      ]
    },
    "bloom-quiz": {
      "emits": [
        { "event": "UI:ANSWER_BLOOM", "trigger": "click", "payload": { "questionId": "string", "selectedIndex": "number", "isCorrect": "boolean" } },
        { "event": "UI:REVEAL_ANSWER", "trigger": "click", "payload": { "questionId": "string" } }
      ]
    },
    "code-block": {
      "emits": [
        { "event": "UI:COPY_CODE", "trigger": "click", "payload": { "code": "string", "language": "string" } }
      ]
    },
    "note-list": {
      "emits": [
        { "event": "UI:ADD_NOTE", "trigger": "click", "payload": {} }
      ]
    },
    "note-item": {
      "emits": [
        { "event": "UI:SELECT_NOTE", "trigger": "click", "payload": { "noteId": "string" } },
        { "event": "UI:DELETE_NOTE", "trigger": "click", "payload": { "noteId": "string" } },
        { "event": "UI:EDIT_NOTE", "trigger": "click", "payload": { "noteId": "string", "newTitle": "string" } },
        { "event": "UI:EXPAND_NOTE", "trigger": "click", "payload": { "noteId": "string", "expanded": "boolean" } },
        { "event": "UI:ADD_CHILD_NOTE", "trigger": "click", "payload": { "parentId": "string" } }
      ]
    },
    "note-content": {
      "emits": [
        { "event": "UI:EDIT_NOTE_CONTENT", "trigger": "click", "payload": { "noteId": "string" } },
        { "event": "UI:SAVE_NOTE_CONTENT", "trigger": "blur", "payload": { "noteId": "string", "content": "string" } }
      ]
    },
    "layer-navigator": {
      "emits": [
        { "event": "UI:SELECT_LAYER", "trigger": "click", "payload": { "layerNumber": "number" } },
        { "event": "UI:PREV_LAYER", "trigger": "click", "payload": { "layerNumber": "number" } },
        { "event": "UI:NEXT_LAYER", "trigger": "click", "payload": { "layerNumber": "number" } }
      ]
    },
    "learning-goal": {
      "emits": [
        { "event": "UI:EDIT_GOAL", "trigger": "click", "payload": { "layerNumber": "number", "graphId": "string" } },
        { "event": "UI:SAVE_GOAL", "trigger": "click", "payload": { "layerNumber": "number", "graphId": "string", "goal": "string" } },
        { "event": "UI:CANCEL_EDIT_GOAL", "trigger": "click", "payload": { "layerNumber": "number", "graphId": "string" } }
      ]
    },
    "concept-meta-tags": {
      "emits": [
        { "event": "UI:NAVIGATE_TO_PARENT", "trigger": "click", "payload": { "parentName": "string" } }
      ]
    },
    "lesson-template": {
      "emits": [
        { "event": "UI:LESSON_COMPLETE", "trigger": "click", "payload": { "lessonId": "string" } },
        { "event": "UI:LESSON_NEXT", "trigger": "click", "payload": { "currentLessonId": "string" } },
        { "event": "UI:LESSON_PREV", "trigger": "click", "payload": { "currentLessonId": "string" } },
        { "event": "UI:TOGGLE_SIDEBAR", "trigger": "click", "payload": { "open": "boolean" } },
        { "event": "UI:SELECT_LESSON", "trigger": "click", "payload": { "lessonId": "string" } }
      ]
    },
    "concept-detail-template": {
      "emits": [
        { "event": "UI:START_LESSON", "trigger": "click", "payload": { "conceptId": "string" } },
        { "event": "UI:START_PRACTICE", "trigger": "click", "payload": { "conceptId": "string" } },
        { "event": "UI:NAVIGATE_PREREQUISITE", "trigger": "click", "payload": { "prerequisiteName": "string", "fromConcept": "string" } },
        { "event": "UI:BACK", "trigger": "click", "payload": { "fromConcept": "string" } },
        { "event": "UI:GENERATE_LESSON", "trigger": "click", "payload": { "conceptId": "string" } }
      ]
    },
    "knowledge-graph-template": {
      "emits": [
        { "event": "UI:SELECT_NODE", "trigger": "click", "payload": { "nodeId": "string", "graphId": "string" } },
        { "event": "UI:SELECT_LAYER", "trigger": "click", "payload": { "layerNumber": "number" } },
        { "event": "UI:TOGGLE_VIEW", "trigger": "click", "payload": { "mode": "string", "graphId": "string" } },
        { "event": "UI:VIEW_CONCEPT", "trigger": "click", "payload": { "conceptId": "string" } }
      ]
    }
  }
}
